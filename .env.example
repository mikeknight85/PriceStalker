# PriceStalker — docker-compose environment
#
# Copy to .env and adjust values. All variables have safe defaults; you only
# need to set what you want to override.

# ---------------------------------------------------------------------------
# Fresh install (default)
# ---------------------------------------------------------------------------
# Leave everything commented. Defaults will create a clean `pricestalker`
# database in a `pricestalker_postgres_data` volume on port 80.

# ---------------------------------------------------------------------------
# Secrets (always override in production)
# ---------------------------------------------------------------------------
# JWT_SECRET=replace-with-a-long-random-string
# POSTGRES_PASSWORD=replace-with-a-strong-password

# ---------------------------------------------------------------------------
# Migrating from upstream clucraft/PriceGhost
# ---------------------------------------------------------------------------
# If you are already running clucraft/PriceGhost and want to keep your data
# without renaming the database or moving volumes, uncomment the block below.
# This lets PriceStalker attach to your existing `priceghost` database and
# volume with zero data movement.
#
# POSTGRES_DB=priceghost
# DATABASE_URL=postgresql://postgres:postgres@postgres:5432/priceghost
# POSTGRES_VOLUME_NAME=priceghost_postgres_data
#
# If you used a non-default docker-compose project name upstream (e.g. your
# directory was named `PriceGhost`), your actual volume is likely named
# `priceghost_postgres_data` — verify with:   docker volume ls

# ---------------------------------------------------------------------------
# Optional overrides
# ---------------------------------------------------------------------------
# FRONTEND_PORT=8080            # change if port 80 is in use
# POSTGRES_USER=postgres
