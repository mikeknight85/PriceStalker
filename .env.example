# PriceStalker — docker-compose environment
#
# Copy to .env and edit:   cp .env.example .env
#
# POSTGRES_PASSWORD and JWT_SECRET are REQUIRED. The stack refuses to start
# without them rather than falling back to a well-known default, which would
# mean every deployment shared the same database password and session key.

# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------
POSTGRES_PASSWORD=replace-with-a-strong-password

# Signs session tokens. Changing it logs everyone out. Generate one with:
#   openssl rand -base64 48
JWT_SECRET=replace-with-a-long-random-string

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# Defaults to `priceghost` so that installs upgrading from earlier versions
# keep their existing database. A fresh install may use any name.
# POSTGRES_DB=priceghost
# POSTGRES_USER=postgres
# POSTGRES_VOLUME_NAME=pricestalker_postgres_data

# ---------------------------------------------------------------------------
# Migrating from upstream clucraft/PriceGhost
# ---------------------------------------------------------------------------
# Already running clucraft/PriceGhost and want to keep your data without
# renaming the database or moving volumes? Point the stack at the existing
# database and volume:
#
# POSTGRES_DB=priceghost
# POSTGRES_VOLUME_NAME=priceghost_postgres_data
#
# If your compose project name differed upstream (e.g. the directory was named
# `PriceGhost`), the volume is likely `priceghost_postgres_data` — confirm with:
#   docker volume ls
#
# Schema migrations run automatically on first boot. Take a database backup
# first: the upgrade is one-way and rewrites the notifications table.

# ---------------------------------------------------------------------------
# General
# ---------------------------------------------------------------------------
# FRONTEND_PORT=80              # host port for the web UI
# IMAGE_REGISTRY=ghcr.io        # registry host; e.g. localhost:5000
# IMAGE_NAMESPACE=mikeknight85  # GHCR owner or registry namespace
# IMAGE_TAG=latest              # `beta` to track pre-releases, or pin a version
# TZ=UTC                        # affects log timestamps and scheduled tasks
# LOG_LEVEL=info                # debug | info | warn | error
# BACKEND_MEM_LIMIT=1g
# REDACT_API_KEYS=false         # Set to "true" to mask AI API keys in the Admin UI and disable the reveal (eye icon) button for added security

# ---------------------------------------------------------------------------
# SSO / OIDC
# ---------------------------------------------------------------------------
# Master switch. When this is not "true", every /api/auth/oidc route returns 404
# and the login page shows local login only -- regardless of what is configured
# in the UI. Must be the string "true"; compose will not coerce a YAML boolean.
# ENABLE_SSO=true
#
# Public base URL of this instance. Required when SSO is enabled: both the OIDC
# redirect URI and the post-login landing page are derived from it.
# PUBLIC_URL=https://pricestalker.example.com
#
# Only needed when the redirect URI registered with your provider differs from
# ${PUBLIC_URL}/api/auth/oidc/callback
# OIDC_REDIRECT_URI_OVERRIDE=
#
# Issuer URL, client ID and client secret are NOT set here. An admin configures
# them in the UI under Admin -> Authentication; they live in the database.

# ---------------------------------------------------------------------------
# Optional
# ---------------------------------------------------------------------------
# Bootstrap/emergency API token. Grants admin access without a login, so leave
# unset unless you need it.
# ADMIN_API_TOKEN=

# SMTP fallback, used only to send database-health alerts when the app's own
# notification channels cannot be reached.
# SMTP_FALLBACK_HOST=
# SMTP_FALLBACK_PORT=587
# SMTP_FALLBACK_FROM=
# ADMIN_ALERT_EMAIL=

# ---------------------------------------------------------------------------
# Remote scraper (optional)
# ---------------------------------------------------------------------------
# A separate stealth-browser service for retailers that block ordinary
# scraping. Off by default; the backend falls back to in-process scraping.
#
#   docker compose --profile remotescraper up -d
#
# Then set the URL in the UI under Admin -> System -> Network & Integration:
#   http://remotescraper:5100/scrape
