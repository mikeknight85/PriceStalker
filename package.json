{
  "name": "pricestalker-workspace",
  "private": true,
  "engines": {
    "node": ">=24.18.0 <25",
    "pnpm": ">=11.4.0 <12"
  },
  "volta": {
    "node": "24.18.0",
    "pnpm": "11.4.0"
  },
  "packageManager": "pnpm@11.4.0",
  "workspaces": [
    "frontend",
    "backend",
    "remotescraper"
  ],
  "scripts": {
    "install:all": "pnpm install",
    "build:backend": "pnpm --filter pricestalker-backend run build",
    "build:frontend": "pnpm --filter pricestalker-frontend run build",
    "build:remotescraper": "pnpm --filter stealth-scraper run build",
    "build:all": "pnpm run build:backend && pnpm run build:frontend && pnpm run build:remotescraper",
    "start:backend": "pnpm --filter pricestalker-backend start",
    "start:frontend": "pnpm --filter pricestalker-frontend run dev",
    "db:migrate": "pnpm --filter pricestalker-backend run db:migrate",
    "db:migrate:dev": "pnpm --filter pricestalker-backend run db:migrate:dev",
    "tree": "pnpm dlx tree-node-cli -I \"node_modules|build|dist|\\.git|\\.js\\.map|\\.d\\.ts\" -a",
    "lint": "node scripts/check-no-emoji.mjs"
  },
  "devDependencies": {
    "@mermaid-js/mermaid-cli": "^11.12.0"
  },
  "version": "2.0.0-beta.1"
}
