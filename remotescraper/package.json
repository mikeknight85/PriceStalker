{
  "name": "stealth-scraper",
  "version": "1.0.36",
  "description": "Bulletproof Puppeteer scraper with stealth and adblocker",
  "main": "src/remotescraper.mjs",
  "type": "module",
  "scripts": {
    "build": "esbuild src/remotescraper.mjs --bundle --platform=node --target=node20 --outfile=dist/remotescraper.cjs --minify --format=cjs --external:puppeteer --external:puppeteer-extra --external:puppeteer-extra-plugin-stealth --external:puppeteer-extra-plugin-adblocker"
  },
  "dependencies": {
    "axios": "1.14.0",
    "express": "^4.19.2",
    "jsdom": "^29.0.2",
    "puppeteer": "^22.6.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-adblocker": "^2.13.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  },
  "devDependencies": {
    "esbuild": "^0.20.0"
  }
}
